# Принимаем условия использования (требуется AI-Dock)
ENV PROVISIONING_SCRIPT=""

# -----------------------------------------------------------------------------
# Здесь на следующих этапах будем добавлять:
# - COPY provisioning/default.sh /opt/ai-dock/bin/provisioning.sh
# - COPY config/ /workspace/stable-diffusion-webui-forge/config/
# - модели и LoRA
