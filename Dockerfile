LABEL version="0.1.0"

# -----------------------------------------------------------------------------
# Дефолтные переменные окружения
# Их можно переопределить в шаблоне Vast.ai при запуске
# -----------------------------------------------------------------------------

# Часовой пояс
ENV TZ="Europe/Moscow"

# Web-авторизация для Forge UI (защита от ботов)
# При желании переопределите в Vast.ai через env-переменные
